# Application Settings
PROJECT_NAME="Chances Of Admission (India)"
API_V1_STR="/api/v1"
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# Networking & CORS
# In production, specify your frontend URL
CORS_ORIGINS=["https://chances-of-admission.vercel.app"]

# Database Configuration (PostgreSQL/SQLite)
# If using SQLite locally:
# DATABASE_URL=sqlite:///./chances.db
# If using PostgreSQL (Render DB):
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chances_db
POSTGRES_PORT=5432

# Model Artifacts
MODEL_PATH=ml/artifacts/best_model.joblib
