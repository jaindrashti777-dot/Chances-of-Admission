# Database Configuration
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:password@localhost:5432/admission_chances

# Security Configuration
# Comma-separated list or JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5173", "https://your-production-url.vercel.app"]

# Application Settings
PROJECT_NAME="Chances of Admission API"
API_V1_STR="/api/v1"

# Note: Never commit production credentials (e.g. cloud database passwords) to git.
# Add .env to your .gitignore.
